# Copy this file to .env.local for local development ("vercel dev")
# and never commit the copy — .gitignore already excludes it.
#
# In production, set these in the Vercel dashboard instead:
# Project -> Settings -> Environment Variables.

# Resend API key. Create one at https://resend.com/api-keys after
# signing up. Keep this secret — it can send email as you.
RESEND_API_KEY=

# The inbox that receives every enquiry submitted through the contact
# form (your Gmail address).
CONTACT_TO_EMAIL=

# The "from" address both emails (owner notification + client
# acknowledgement) are sent from. Resend requires this to be either:
#   - onboarding@resend.dev, for testing without any domain setup, or
#   - an address on a domain you've verified in the Resend dashboard
#     (Domains -> Add Domain), once you have one.
CONTACT_FROM_EMAIL=
